ENVIRONMENT=development
DATABASE_URL=sqlite+aiosqlite:///./montgowork.db
CREDIT_API_URL=http://localhost:8001
CREDIT_API_KEY=montgowork-dev
# LLM Provider — choose one: anthropic | openai | gemini | mock
# If the selected provider's API key is missing, the server automatically
# falls back to "mock" (streams a placeholder response, no API call made).
# Set LLM_PROVIDER=mock explicitly for zero-config local development.
LLM_PROVIDER=anthropic
# LLM_PROVIDER=mock   # ← uncomment for local dev without any API key

# Anthropic (Claude) — https://console.anthropic.com
ANTHROPIC_API_KEY=

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o

# Google Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

BRIGHTDATA_API_KEY=
BRIGHTDATA_DATASET_ID=
